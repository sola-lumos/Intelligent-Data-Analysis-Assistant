APP_ENV=dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SQLITE_DB_PATH=./data/app.db

# 百炼 DashScope（OpenAI 兼容 Chat Completions）。本地复制为 backend/.env 后填写：
# DASHSCOPE_API_KEY=你的密钥
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TEMPERATURE=0

# 可选：数据洞察二次调用温度（默认见 app/core/config.py）
# QWEN_INSIGHT_TEMPERATURE=0.2
# VIZ_INSIGHT_MAX_PREVIEW_ROWS=40

# SSE「打字机」
# SSE_TYPING_DELAY_SECONDS=0
# SSE_ANSWER_CHUNK_CHARS=512
